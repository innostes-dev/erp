{
  "name": "mono",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many -t dev --projects=shell,api-gateway --parallel",
    "build": "nx build",
    "test": "nx test",
    "lint": "nx lint",
    "typecheck": "nx typecheck",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:typecheck": "nx affected -t typecheck",
    "graph": "nx graph",
    "g:module": "nx g @mono/generators:module",
    "g:service": "nx g @mono/generators:service",
    "db:generate": "drizzle-kit generate --config=apps/api-gateway/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=apps/api-gateway/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=apps/api-gateway/drizzle.config.ts",
    "db:seed": "ts-node -r tsconfig-paths/register apps/api-gateway/src/database/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.2",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.41.0",
    "lucide-react": "^1.14.0",
    "mitt": "^3.0.1",
    "next": "^15.0.0",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "server-only": "^0.0.1",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^2.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@nx/eslint": "^22.0.0",
    "@nx/eslint-plugin": "^22.0.0",
    "@nx/jest": "^22.0.0",
    "@nx/js": "^22.0.0",
    "@nx/nest": "^22.0.0",
    "@nx/next": "^22.0.0",
    "@nx/playwright": "^22.0.0",
    "@nx/workspace": "^22.0.0",
    "@playwright/test": "^1.44.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.8",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "msw": "^2.3.0",
    "nx": "^22.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
