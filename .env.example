# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/innostes_os

# JWT — server refuses to start if shorter than 64 characters
# Generate a secure one in production!
JWT_SECRET=this-is-a-very-long-and-secure-secret-that-is-at-least-64-characters-long-for-testing

# Sessions
REFRESH_TOKEN_EXPIRES_DAYS=7

# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
