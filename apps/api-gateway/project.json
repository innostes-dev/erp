{
  "name": "api-gateway",
  "$schema": "../../node_modules/nx/schemas/project.json",
  "sourceRoot": "apps/api-gateway/src",
  "projectType": "application",
  "tags": ["type:app", "scope:infra", "platform:server"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node -r tsconfig-paths/register apps/api-gateway/src/main.ts",
        "cwd": "{workspaceRoot}",
        "envFile": ".env",
        "env": {
          "TS_NODE_PROJECT": "apps/api-gateway/tsconfig.json",
          "PORT": "3001"
        }
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api-gateway",
        "main": "apps/api-gateway/src/main.ts",
        "tsConfig": "apps/api-gateway/tsconfig.json",
        "assets": []
      }
    }
  }
}
