{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "jsx": "preserve",
    "types": ["node"],
    "paths": {
      "@innostes/core/design-system": ["libs/core/design-system/src/index.ts"],
      "@innostes/core/database": ["libs/core/database/src/index.ts"],
      "@innostes/core/bridge": ["libs/core/bridge/src/index.ts"],
      "@innostes/modules/hrms/feature-ui": ["libs/modules/hrms/feature-ui/src/index.ts"],
      "@innostes/modules/hrms/api-logic": ["libs/modules/hrms/api-logic/src/index.ts"],
      "@innostes/modules/hrms/data-access": ["libs/modules/hrms/data-access/src/index.ts"],
      "@innostes/modules/*": ["libs/modules/*/src/index.ts"],
      "@innostes/core/*": ["libs/core/*/src/index.ts"],
      "@innostes/shared": ["libs/shared/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
