{
  "$schema": "http://json-schema.org/schema",
  "cli": "nx",
  "id": "service",
  "title": "NestJS Service Generator",
  "description": "Scaffold a new NestJS domain microservice",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Service name (e.g. payments, catalog)",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "What is the service name?"
    }
  },
  "required": ["name"]
}
