{
  "$schema": "http://json-schema.org/schema",
  "cli": "nx",
  "id": "module",
  "title": "Domain Module Generator",
  "description": "Scaffold a new domain module with feature/ui/data-access/utils layers",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Module name (e.g. payments, catalog)",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "What is the module name?"
    }
  },
  "required": ["name"]
}
